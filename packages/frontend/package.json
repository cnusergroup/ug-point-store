{
  "name": "points-mall-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "积分商城前端 - Taro + React",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "build:weapp": "npx taro build --type weapp",
    "build:h5": "npx taro build --type h5",
    "dev:weapp": "npx taro build --type weapp --watch",
    "dev:h5": "npx taro build --type h5 --watch"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "dependencies": {
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@tarojs/cli": "4.0.9",
    "@tarojs/components": "4.0.9",
    "@tarojs/helper": "4.0.9",
    "@tarojs/plugin-framework-react": "4.0.9",
    "@tarojs/plugin-platform-h5": "4.0.9",
    "@tarojs/plugin-platform-weapp": "4.0.9",
    "@tarojs/runtime": "4.0.9",
    "@tarojs/shared": "4.0.9",
    "@tarojs/taro": "4.0.9",
    "babel-preset-taro": "^4.1.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "taro-ui": "^3.3.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@babel/runtime": "^7.24.0",
    "@tarojs/webpack5-runner": "4.0.9",
    "@types/react": "^18.3.0",
    "sass": "^1.77.0",
    "typescript": "^5.7.0",
    "webpack": "^5.91.0"
  }
}
